@using Microsoft.AspNetCore.Components.Authorization
@using TccManager.Client.Layout

<CascadingAuthenticationState>
    @* Host único de diálogos/notificações/tooltips/context menu (DialogService, NotificationService,
       TooltipService, ContextMenuService). Fica aqui, acima do Router, para servir tanto o
       LoginLayout (sem MainLayout) quanto o MainLayout. *@
    <RadzenComponents />
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    <TccManager.Client.Layout.RedirectToLogin />
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Não encontrado</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <p role="alert">Desculpe, não há nada neste endereço.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>