@page "/login"
@layout LoginLayout
@using TccManager.Shared.DTOs
@using TccManager.Client.Providers
@using Blazored.LocalStorage
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage
@inject CustomAuthStateProvider AuthStateProvider
@inject NotificationService NotificationService

<PageTitle>Login</PageTitle>

<RadzenCard Variant="Variant.Filled" class="rz-shadow-2" style="width: 100%; max-width: 400px;">
    <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center" class="rz-mb-4">
        <RadzenText TextStyle="TextStyle.H5" class="rz-my-0">Login TCC Manager</RadzenText>
        <RadzenText TextStyle="TextStyle.Body2" class="rz-my-0">Entre com suas credenciais</RadzenText>
    </RadzenStack>

    <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
        <DataAnnotationsValidator />

        <RadzenStack Gap="1rem">
            <RadzenFormField Text="Email" Variant="Variant.Outlined" style="width: 100%;">
                <RadzenTextBox Name="Email" @bind-Value="loginModel.Email" Placeholder="seu@email.com" style="width: 100%;" />
            </RadzenFormField>

            <RadzenFormField Text="Senha" Variant="Variant.Outlined" style="width: 100%;">
                <RadzenPassword Name="Senha" @bind-Value="loginModel.Senha" Placeholder="******" style="width: 100%;" />
            </RadzenFormField>

            <RadzenButton ButtonType="ButtonType.Submit"
                          Text="Entrar"
                          IsBusy="carregando"
                          BusyText="Entrando..."
                          ButtonStyle="ButtonStyle.Primary"
                          style="width: 100%;" />
        </RadzenStack>
    </EditForm>
</RadzenCard>

@code {
    [SupplyParameterFromQuery(Name = "expirado")]
    [Parameter]
    public string? Expirado { get; set; }

    private LoginDto loginModel = new();
    private bool carregando = false;

    protected override void OnInitialized()
    {
        if (Expirado == "1")
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Warning,
                Summary = "Sessão expirada",
                Detail = "Sua sessão expirou. Faça login novamente.",
                Duration = 6000
            });
        }
    }

    private async Task HandleLogin()
    {
        carregando = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);
            if (response.IsSuccessStatusCode)
            {
                var resultado = await response.Content.ReadFromJsonAsync<LoginResponseDto>();
                await LocalStorage.SetItemAsync("authToken", resultado!.Token);
                await LocalStorage.SetItemAsync("refreshToken", resultado.RefreshToken);
                AuthStateProvider.NotifyUserAuthentication(resultado.Token);

                Navigation.NavigateTo("/");
            }
            else
            {
                var mensagem = "Credenciais inválidas. Tente novamente.";
                try
                {
                    // AuthController retorna Unauthorized(string): o formatter padrão do
                    // ASP.NET Core serializa string como text/plain (sem aspas), não JSON —
                    // por isso o corpo é lido como texto puro, não com ReadFromJsonAsync.
                    var corpo = await response.Content.ReadAsStringAsync();
                    if (!string.IsNullOrWhiteSpace(corpo))
                        mensagem = corpo;
                }
                catch (Exception)
                {
                    // Corpo em formato inesperado — mantém a mensagem genérica de fallback.
                }

                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Error,
                    Summary = "Falha no login",
                    Detail = mensagem,
                    Duration = 5000
                });
            }
        }
        catch (Exception)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Falha ao entrar",
                Detail = "Não foi possível entrar. Tente novamente em instantes.",
                Duration = 5000
            });
        }
        finally
        {
            carregando = false;
        }
    }
}
