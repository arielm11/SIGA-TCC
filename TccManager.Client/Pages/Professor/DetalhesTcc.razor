@page "/professor/tcc/{TccId:int}"
@using Microsoft.AspNetCore.Authorization
@using TccManager.Shared.Models
@using TccManager.Shared.DTOs
@using TccManager.Shared.Enums
@attribute [Authorize(Roles = "Professor")]
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<div class="container mt-4">
    <button class="btn btn-outline-secondary mb-3" @onclick='() => Navigation.NavigateTo("/professor/dashboard")'>
        <i class="bi bi-arrow-left"></i> Voltar ao Dashboard
    </button>

    @if (carregando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Carregando dados do orientando...</p>
        </div>
    }
    else if (tcc != null)
    {
        <div class="card shadow-sm mb-4 border-primary">
            <div class="card-body">
                <h3 class="text-primary fw-bold">@tcc.Titulo</h3>
                <h5 class="text-muted"><i class="bi bi-person-fill me-2"></i>Aluno: @tcc.Aluno?.Nome</h5>
                <hr />
                <p><strong>Resumo:</strong> @tcc.Resumo</p>
                <span class="badge bg-info text-dark">Status: @tcc.Status</span>
            </div>
        </div>

        <ul class="nav nav-tabs mb-4">
            <li class="nav-item">
                <button class="nav-link @(abaAtiva == "entregas" ? "active fw-bold" : "")" @onclick='() => abaAtiva = "entregas"'>
                    <i class="bi bi-folder2-open me-2"></i> Entregas do Aluno
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(abaAtiva == "acompanhamentos" ? "active fw-bold" : "")" @onclick='() => abaAtiva = "acompanhamentos"'>
                    <i class="bi bi-calendar-event me-2"></i> Registo de Reuniões
                </button>
            </li>
        </ul>

        @if (abaAtiva == "entregas")
        {
            @if (!tcc.Entregas.Any())
            {
                <div class="alert alert-secondary">Este aluno ainda não enviou nenhum arquivo.</div>
            }
            else
            {
                <div class="row">
                    @foreach (var entrega in tcc.Entregas)
                    {
                        <div class="col-12 mb-3">
                            <div class="card shadow-sm">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5 class="mb-1">@entrega.Titulo <span class="badge bg-secondary ms-2">@entrega.Tipo</span></h5>
                                        <p class="text-muted small mb-0">Enviado em: @entrega.DataEnvio.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                                        
                                        @if (!string.IsNullOrEmpty(entrega.Feedback))
                                        {
                                            <div class="mt-2 text-success fw-bold"><i class="bi bi-check-all me-1"></i> Avaliado (Nota: @(entrega.Nota?.ToString() ?? "N/A"))</div>
                                        }
                                        else
                                        {
                                            <div class="mt-2 text-warning fw-bold"><i class="bi bi-clock-history me-1"></i> Aguardando Avaliação</div>
                                        }
                                    </div>
                                    <div class="text-end">
                                        <a href="@($"{Http.BaseAddress?.ToString().TrimEnd('/')}{entrega.ArquivoCaminho}")" target="_blank" class="btn btn-outline-primary me-2">
                                            <i class="bi bi-download"></i> Baixar Arquivo
                                        </a>
                                        <button class="btn btn-success" @onclick="() => AbrirModalFeedback(entrega)">
                                            <i class="bi bi-chat-square-text"></i> @(string.IsNullOrEmpty(entrega.Feedback) ? "Avaliar" : "Editar Avaliação")
                                        </button>
                                    </div>
                                </div>

                                @if (entregaEmAvaliacao == entrega.Id)
                                {
                                    <div class="card-footer bg-light border-top p-3 animate__animated animate__fadeIn">
                                        <EditForm Model="feedbackAtual" OnValidSubmit="() => SalvarFeedback(entrega.Id)">
                                            <DataAnnotationsValidator />
                                            <div class="row">
                                                <div class="col-md-3 mb-3">
                                                    <label class="form-label fw-bold">Nota (Opcional)</label>
                                                    <InputNumber class="form-control" @bind-Value="feedbackAtual.Nota" />
                                                </div>
                                                <div class="col-md-9 mb-3">
                                                    <label class="form-label fw-bold">Comentários / Parecer</label>
                                                    <InputTextArea class="form-control" @bind-Value="feedbackAtual.Feedback" rows="3" />
                                                    <ValidationMessage For="@(() => feedbackAtual.Feedback)" class="text-danger" />
                                                </div>
                                            </div>
                                            <div class="d-flex justify-content-end gap-2">
                                                <button type="button" class="btn btn-secondary" @onclick="FecharModalFeedback">Cancelar</button>
                                                <button type="submit" class="btn btn-success" disabled="@salvando">Salvar Feedback</button>
                                            </div>
                                        </EditForm>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }

        @if (abaAtiva == "acompanhamentos")
        {
            <div class="card shadow-sm mb-4 border-@(acompanhamentoEmEdicaoId.HasValue ? "warning" : "light")">
                <div class="card-header bg-@(acompanhamentoEmEdicaoId.HasValue ? "warning text-dark" : "light text-dark") fw-bold">
                    <i class="bi @(acompanhamentoEmEdicaoId.HasValue ? "bi-pencil-square" : "bi-plus-circle") me-2"></i>
                    @(acompanhamentoEmEdicaoId.HasValue ? "Editar Ata de Reunião" : "Nova Ata de Reunião")
                </div>
                <div class="card-body">
                    <EditForm Model="novoAcompanhamento" OnValidSubmit="SalvarAcompanhamento">
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold">Data da Reunião</label>
                                <InputDate class="form-control" @bind-Value="novoAcompanhamento.DataReuniao" />
                                <ValidationMessage For="@(() => novoAcompanhamento.DataReuniao)" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Ata / Assuntos Discutidos</label>
                            <InputTextArea class="form-control" @bind-Value="novoAcompanhamento.Ata" rows="4" />
                            <ValidationMessage For="@(() => novoAcompanhamento.Ata)" />
                        </div>

                        <div class="text-end">
                            @if (acompanhamentoEmEdicaoId.HasValue)
                            {
                                <button type="button" class="btn btn-secondary me-2" @onclick="CancelarEdicaoAcompanhamento">Cancelar Edição</button>
                            }
                            <button type="submit" class="btn btn-primary" disabled="@salvandoAcompanhamento">
                                @if (salvandoAcompanhamento)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                <i class="bi bi-save me-1"></i> @(acompanhamentoEmEdicaoId.HasValue ? "Salvar Alterações" : "Gravar Registo")
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>

            <h5 class="fw-bold mb-3"><i class="bi bi-journal-text me-2"></i> Histórico de Reuniões</h5>
            @if (!tcc.Acompanhamentos.Any())
            {
                <div class="alert alert-secondary">Nenhum registo de acompanhamento efetuado até ao momento.</div>
            }
            else
            {
                <div class="accordion" id="accordionAcompanhamentos">
                    @foreach (var ata in tcc.Acompanhamentos)
                    {
                        <div class="accordion-item mb-2 border rounded shadow-sm">
                            <h2 class="accordion-header" id="heading_@ata.Id">
                                <button class="accordion-button collapsed bg-light text-dark fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#collapse_@ata.Id">
                                    <i class="bi bi-calendar2-check text-primary me-2"></i>
                                    Reunião de @ata.DataReuniao.ToLocalTime().ToString("dd/MM/yyyy")
                                </button>
                            </h2>
                            <div id="collapse_@ata.Id" class="accordion-collapse collapse" data-bs-parent="#accordionAcompanhamentos">
                                <div class="accordion-body">
                                    <div style="white-space: pre-line;">@ata.Ata</div>
                                    
                                    <div class="d-flex justify-content-end gap-2 mt-3 pt-3 border-top">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => PrepararEdicaoAcompanhamento(ata)">
                                            <i class="bi bi-pencil"></i> Editar
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ExcluirAcompanhamento(ata.Id)">
                                            <i class="bi bi-trash"></i> Excluir
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    }
</div>

@code {
    [Parameter]
    public int TccId { get; set; }

    private bool carregando = true;
    private bool salvando = false;
    private Tcc? tcc;
    
    private int? entregaEmAvaliacao;
    private FeedbackDto feedbackAtual = new();

    private string abaAtiva = "entregas";
    private AcompanhamentoDto novoAcompanhamento = new();
    private bool salvandoAcompanhamento = false;
    private int? acompanhamentoEmEdicaoId = null;

    protected override async Task OnInitializedAsync()
    {
        await CarregarTcc();
    }

    private async Task CarregarTcc()
    {
        carregando = true;
        try
        {
            tcc = await Http.GetFromJsonAsync<Tcc>($"api/orientador/tcc/{TccId}");
        }
        catch { await JSRuntime.InvokeVoidAsync("alert", "Erro ao carregar os dados."); }
        finally { carregando = false; }
    }

    private void AbrirModalFeedback(Entrega entrega)
    {
        entregaEmAvaliacao = entrega.Id;

        feedbackAtual = new FeedbackDto
        {
            Feedback = entrega.Feedback ?? "",
            Nota = entrega.Nota
        };
    }

    private void FecharModalFeedback()
    {
        entregaEmAvaliacao = null;
        feedbackAtual = new();
    }

    private async Task SalvarFeedback(int idEntrega)
    {
        salvando = true;
        try
        {
            var response = await Http.PostAsJsonAsync($"api/orientador/entregas/{idEntrega}/feedback", feedbackAtual);
            
            if (response.IsSuccessStatusCode)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Avaliação salva com sucesso!");
                FecharModalFeedback();
                await CarregarTcc();
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", "Erro ao salvar a avaliação.");
            }
        }
        finally { salvando = false; }
    }

    private async Task SalvarAcompanhamento()
    {
        salvandoAcompanhamento = true;
        try
        {
            HttpResponseMessage response;

            if (acompanhamentoEmEdicaoId.HasValue)
            {
                // Edição (PUT)
                response = await Http.PutAsJsonAsync($"api/orientador/tcc/{TccId}/acompanhamentos/{acompanhamentoEmEdicaoId.Value}", novoAcompanhamento);
            }
            else
            {
                // Criação (POST)
                response = await Http.PostAsJsonAsync($"api/orientador/tcc/{TccId}/acompanhamentos", novoAcompanhamento);
            }
            
            if (response.IsSuccessStatusCode)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Ata de reunião salva com sucesso!");
                CancelarEdicaoAcompanhamento();
                await CarregarTcc();
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", "Erro ao guardar o acompanhamento.");
            }
        }
        finally { salvandoAcompanhamento = false; }
    }

    private void PrepararEdicaoAcompanhamento(Acompanhamento ata)
    {
        acompanhamentoEmEdicaoId = ata.Id;
        novoAcompanhamento = new AcompanhamentoDto
        {
            DataReuniao = ata.DataReuniao,
            Ata = ata.Ata
        };
        
        JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0);
    }

    private void CancelarEdicaoAcompanhamento()
    {
        acompanhamentoEmEdicaoId = null;
        novoAcompanhamento = new AcompanhamentoDto();
    }

    private async Task ExcluirAcompanhamento(int idAcompanhamento)
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", "Tem certeza que deseja excluir esta ata? Esta ação não pode ser desfeita.");
        if (!confirm) return;

        try
        {
            var response = await Http.DeleteAsync($"api/orientador/tcc/{TccId}/acompanhamentos/{idAcompanhamento}");
            
            if (response.IsSuccessStatusCode)
            {
                await CarregarTcc();
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", "Erro ao excluir o acompanhamento.");
            }
        }
        catch { await JSRuntime.InvokeVoidAsync("alert", "Erro de conexão ao excluir."); }
    }
}