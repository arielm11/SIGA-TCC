@page "/coordenador/dashboard"
@using Microsoft.AspNetCore.Authorization
@using TccManager.Shared.DTOs
@attribute [Authorize(Roles = "Coordenador")]
@inject HttpClient Http
@inject IJSRuntime JSRuntime

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-bar-chart-fill me-2"></i> Painel da Coordenação</h2>

    @if (carregando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Calculando estatísticas...</p>
        </div>
    }
    else
    {
        @if (stats != null)
        {
            <div class="row mb-4 g-3">
                <div class="col-md-3">
                    <div class="card bg-primary text-white h-100 shadow-sm border-0">
                        <div class="card-body text-center">
                            <h1 class="display-5 fw-bold">@stats.TotalAtivos</h1>
                            <p class="mb-0">TCCs Ativos</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-warning text-dark h-100 shadow-sm border-0">
                        <div class="card-body text-center">
                            <h1 class="display-5 fw-bold">@stats.PropostasPendentes</h1>
                            <p class="mb-0">Propostas Pendentes</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-info text-dark h-100 shadow-sm border-0">
                        <div class="card-body text-center">
                            <h1 class="display-5 fw-bold">@stats.AguardandoBanca</h1>
                            <p class="mb-0">Aguardando Banca</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-success text-white h-100 shadow-sm border-0">
                        <div class="card-body text-center">
                            <h1 class="display-5 fw-bold">@stats.TccsConcluidos</h1>
                            <p class="mb-0">Concluídos</p>
                        </div>
                    </div>
                </div>
            </div>
        }

        <h4 class="mb-3"><i class="bi bi-inbox me-2"></i> Atribuir Orientadores</h4>
        <div class="card shadow-sm mb-5">
            <div class="card-body">
                @if (pendentes == null || !pendentes.Any())
                {
                    <div class="alert alert-light text-center mb-0">Não há novas propostas pendentes no momento.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Aluno</th>
                                    <th>Título da Proposta</th>
                                    <th>Data de Submissão</th>
                                    <th>Ação</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tcc in pendentes)
                                {
                                    <tr>
                                        <td class="fw-bold">@tcc.NomeAluno</td>
                                        <td>@tcc.Titulo</td>
                                        <td>@tcc.DataCriacao.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                        <td>
                                            <button class="btn btn-sm btn-primary" @onclick="() => AbrirModalDesignacao(tcc)">
                                                <i class="bi bi-person-plus-fill me-1"></i> Designar
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        @if (tccSelecionado != null)
        {
            <div class="card border-primary shadow animate__animated animate__fadeIn mb-4">
                <div class="card-header bg-primary text-white fw-bold">
                    Designar Orientador para: @tccSelecionado.NomeAluno
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">Selecione um professor da lista abaixo. O sistema mostra a carga atual de orientandos de cada um para ajudar na distribuição.</p>
                    
                    <div class="row align-items-center">
                        <div class="col-md-8 mb-3 mb-md-0">
                            <select class="form-select" @bind="professorSelecionadoId">
                                <option value="0">-- Selecione o Professor --</option>
                                @if (professores != null)
                                {
                                    @foreach (var prof in professores)
                                    {
                                        <option value="@prof.Id">
                                            @prof.Nome (Carga: @prof.CargaAtual orientandos)
                                        </option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-4 text-end">
                            <button class="btn btn-secondary me-2" @onclick="FecharModal">Cancelar</button>
                            <button class="btn btn-success" disabled="@(professorSelecionadoId == 0 || enviando)" @onclick="SalvarDesignacao">
                                @if (enviando)
                                {
                                    <span class="spinner-border spinner-border-sm"></span>
                                }
                                Confirmar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private bool carregando = true;
    private bool enviando = false;

    private DashboardCoordenadorDto? stats;
    private List<TccResumoDto>? pendentes;
    private List<ProfessorResumoDto>? professores;

    // Controles do Modal
    private TccResumoDto? tccSelecionado;
    private int professorSelecionadoId = 0;

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        carregando = true;
        try
        {
            stats = await Http.GetFromJsonAsync<DashboardCoordenadorDto>("api/coordenador/dashboard-stats");
            pendentes = await Http.GetFromJsonAsync<List<TccResumoDto>>("api/coordenador/propostas-pendentes");
            var professoresPaginado = await Http.GetFromJsonAsync<PagedResult<ProfessorResumoDto>>($"api/coordenador/professores?pageSize={PaginacaoQuery.MaxPageSize}");
            professores = professoresPaginado?.Items;
        }
        catch { await JSRuntime.InvokeVoidAsync("alert", "Erro ao carregar dados do painel."); }
        finally { carregando = false; }
    }

    private async Task AbrirModalDesignacao(TccResumoDto tcc)
    {
        tccSelecionado = tcc;
        professorSelecionadoId = 0;
        await JSRuntime.InvokeVoidAsync("eval", "window.scrollTo(0, document.body.scrollHeight)");
    }

    private void FecharModal()
    {
        tccSelecionado = null;
        professorSelecionadoId = 0;
    }

    private async Task SalvarDesignacao()
    {
        if (tccSelecionado == null || professorSelecionadoId == 0) return;

        enviando = true;
        try
        {
            var payload = new DesignarOrientadorDto { OrientadorId = professorSelecionadoId };
            var response = await Http.PutAsJsonAsync($"api/coordenador/propostas/{tccSelecionado.Id}/designar-orientador", payload);

            if (response.IsSuccessStatusCode)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Orientador designado! A proposta foi aprovada e o aluno será notificado.");
                FecharModal();
                await CarregarDados(); // Recarrega KPIs e a lista
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", "Erro ao designar orientador.");
            }
        }
        finally { enviando = false; }
    }
}